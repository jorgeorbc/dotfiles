/* ROUNDED THEME FOR ROFI - Gruvbox Material Dark Medium */
/* Adaptado por ChatGPT basado en el trabajo de Newman Sanchez */

* {
    bg0:    #1d2021F2; /* Base background - fondo principal */
    bg1:    #282828;   /* Surface - fondo secundario */
    bg2:    #3c3836B3; /* Overlay translúcido */
    bg3:    #d79921F2; /* Highlight / accentuado (amarillo dorado) */

    fg0:    #ebdbb2;   /* Texto principal (claro, beige) */
    fg1:    #fbf1c7;   /* Más claro (casi blanco cálido) */
    fg2:    #a89984;   /* Comentarios / texto tenue */
    fg3:    #3c3836;   /* Contraste oscuro */
}

@import "template/rounded-template.rasi"

